# ─── Shared secrets ────────────────────────────────────────────────────────
# IMPORTANT: Change these for production!
POSTGRES_PASSWORD=your-super-secret-db-password
SUPABASE_JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# Pre-generated anon key (JWT with role:anon, signed with the JWT secret above).
# Regenerate if you change SUPABASE_JWT_SECRET — see README for instructions.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNzc1MTg4MTI0LCJleHAiOjIwOTA1NDgxMjR9.0GTqaZNg6Rm1xKltMSTNLjf44_FtjjR4J5xkFKf0HQ8

# ─── Supabase Auth ─────────────────────────────────────────────────────────
# Dev: http://localhost:8443   Prod: https://campus.arkandia.co
SUPABASE_URL=http://localhost:8443
SITE_URL=http://localhost:3000

# ─── Backend ──────────────────────────────────────────────────────────────
# DATABASE_URL is constructed in docker-compose.yml from POSTGRES_PASSWORD.
# Only set this if running the backend outside Docker.
# DATABASE_URL=postgresql://postgres:your-super-secret-db-password@localhost:5432/postgres
BACKEND_CORS_ORIGINS=http://localhost:3000
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ─── Frontend ─────────────────────────────────────────────────────────────
# Dev: http://localhost:8443   Prod: https://campus.arkandia.co
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8443
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNzc1MTg4MTI0LCJleHAiOjIwOTA1NDgxMjR9.0GTqaZNg6Rm1xKltMSTNLjf44_FtjjR4J5xkFKf0HQ8
NEXT_PUBLIC_API_URL=http://localhost:8000

