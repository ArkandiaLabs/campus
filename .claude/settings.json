{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|View",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/∑/pre-tool-secret-guard.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|Create|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/agent-hooks/post-tool-quality-log.sh",
            "timeout": 120
          }
        ]
      }
    ]
  }
}